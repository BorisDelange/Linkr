{
  "id": "linkr-analysis-plot-builder",
  "name": {
    "en": "Plot Builder",
    "fr": "Constructeur de graphiques"
  },
  "description": {
    "en": "Interactive plot builder: scatter, line, bar, histogram, boxplot, and violin plots with grouping, colors, and labels.",
    "fr": "Constructeur interactif de graphiques : nuages de points, lignes, barres, histogrammes, boîtes à moustaches et violons avec regroupement, couleurs et légendes."
  },
  "version": "1.0.0",
  "category": "visualization",
  "tags": ["chart", "plot", "scatter", "histogram", "boxplot", "visualization"],
  "runtime": ["component"],
  "languages": [],
  "icon": "ChartScatter",
  "iconColor": "violet",
  "configSchema": {
    "xColumn": {
      "type": "column-select",
      "label": { "en": "X variable", "fr": "Variable X" },
      "row": "columns",
      "section": { "en": "Data", "fr": "Données" },
      "hintWhen": {
        "field": "plotType",
        "values": {
          "scatter": { "en": "required", "fr": "requis" },
          "line": { "en": "required", "fr": "requis" },
          "bar": { "en": "required", "fr": "requis" },
          "histogram": { "en": "required", "fr": "requis" },
          "boxplot": { "en": "categories", "fr": "catégories" },
          "violin": { "en": "categories", "fr": "catégories" }
        }
      }
    },
    "yColumn": {
      "type": "column-select",
      "label": { "en": "Y variable", "fr": "Variable Y" },
      "optional": true,
      "row": "columns",
      "section": { "en": "Data", "fr": "Données" },
      "hintWhen": {
        "field": "plotType",
        "values": {
          "scatter": { "en": "required", "fr": "requis" },
          "line": { "en": "required", "fr": "requis" },
          "bar": { "en": "optional", "fr": "optionnel" },
          "histogram": { "en": "not used", "fr": "non utilisé" },
          "boxplot": { "en": "numeric", "fr": "numérique" },
          "violin": { "en": "numeric", "fr": "numérique" }
        }
      }
    },
    "uniquePer": {
      "type": "column-select",
      "label": { "en": "Unique per", "fr": "Unique par" },
      "optional": true,
      "row": "unique",
      "section": { "en": "Data", "fr": "Données" },
      "description": {
        "en": "Group rows by this column to get one value per entity. Example: group by patient_id to get one value per patient.",
        "fr": "Regroupe les lignes selon cette colonne pour obtenir une valeur par entité. Exemple : grouper par patient_id pour une valeur par patient."
      }
    },
    "uniqueAggregation": {
      "type": "select",
      "label": { "en": "Per-entity function", "fr": "Fonction par entité" },
      "default": "first",
      "row": "unique",
      "section": { "en": "Data", "fr": "Données" },
      "visibleWhen": { "field": "uniquePer", "notEmpty": true },
      "description": {
        "en": "How to reduce multiple rows into one value per entity. Use \"First\" for values that are the same across rows (e.g. age), or \"Mean\" to average measurements.",
        "fr": "Comment réduire plusieurs lignes en une valeur par entité. Utilisez « Premier » pour les valeurs identiques (ex : âge), ou « Moyenne » pour moyenner des mesures."
      },
      "options": [
        { "value": "first", "label": { "en": "First value", "fr": "Première valeur" } },
        { "value": "last", "label": { "en": "Last value", "fr": "Dernière valeur" } },
        { "value": "mean", "label": { "en": "Mean", "fr": "Moyenne" } },
        { "value": "median", "label": { "en": "Median", "fr": "Médiane" } },
        { "value": "min", "label": { "en": "Min", "fr": "Min" } },
        { "value": "max", "label": { "en": "Max", "fr": "Max" } },
        { "value": "sum", "label": { "en": "Sum", "fr": "Somme" } }
      ]
    },
    "groupColumn": {
      "type": "column-select",
      "label": { "en": "Group / Fill", "fr": "Groupe / Remplissage" },
      "optional": true,
      "row": "group",
      "section": { "en": "Data", "fr": "Données" },
      "description": {
        "en": "Split data into groups by this column. Each group gets a different color.",
        "fr": "Sépare les données en groupes selon cette colonne. Chaque groupe a une couleur différente."
      }
    },
    "excludeNA": {
      "type": "boolean",
      "label": { "en": "Exclude NA / missing", "fr": "Exclure NA / manquants" },
      "default": true,
      "section": { "en": "Data", "fr": "Données" },
      "description": {
        "en": "Remove rows where X or Y values are null, empty, or NA before plotting.",
        "fr": "Supprime les lignes où les valeurs X ou Y sont nulles, vides ou NA avant de tracer."
      }
    },

    "title": {
      "type": "string",
      "label": { "en": "Title", "fr": "Titre" },
      "default": "",
      "section": { "en": "Chart", "fr": "Graphique" }
    },
    "plotType": {
      "type": "select",
      "label": { "en": "Plot type", "fr": "Type de graphique" },
      "default": "scatter",
      "section": { "en": "Chart", "fr": "Graphique" },
      "options": [
        { "value": "scatter", "label": { "en": "Scatter plot", "fr": "Nuage de points" } },
        { "value": "line", "label": { "en": "Line plot", "fr": "Lignes" } },
        { "value": "bar", "label": { "en": "Bar chart", "fr": "Barres" } },
        { "value": "histogram", "label": { "en": "Histogram", "fr": "Histogramme" } },
        { "value": "boxplot", "label": { "en": "Boxplot", "fr": "Boîte à moustaches" } },
        { "value": "violin", "label": { "en": "Violin", "fr": "Violon" } }
      ]
    },
    "barMode": {
      "type": "select",
      "label": { "en": "Bar mode", "fr": "Mode des barres" },
      "default": "grouped",
      "section": { "en": "Chart", "fr": "Graphique" },
      "visibleWhen": [
        { "field": "plotType", "value": "histogram" },
        { "field": "groupColumn", "notEmpty": true }
      ],
      "options": [
        { "value": "grouped", "label": { "en": "Grouped", "fr": "Groupées" } },
        { "value": "stacked", "label": { "en": "Stacked", "fr": "Empilées" } },
        { "value": "overlay", "label": { "en": "Overlay", "fr": "Superposées" } }
      ]
    },
    "binMode": {
      "type": "select",
      "label": { "en": "Bin mode", "fr": "Mode bins" },
      "default": "count",
      "visibleWhen": { "field": "plotType", "value": "histogram" },
      "row": "binRow",
      "section": { "en": "Chart", "fr": "Graphique" },
      "options": [
        { "value": "count", "label": { "en": "Number of bins", "fr": "Nombre de barres" } },
        { "value": "width", "label": { "en": "Bin width", "fr": "Largeur de barre" } }
      ]
    },
    "bins": {
      "type": "number",
      "label": { "en": "Bins", "fr": "Barres" },
      "default": 20,
      "min": 2,
      "max": 200,
      "visibleWhen": [
        { "field": "plotType", "value": "histogram" },
        { "field": "binMode", "value": "count" }
      ],
      "row": "binRow",
      "section": { "en": "Chart", "fr": "Graphique" }
    },
    "binWidth": {
      "type": "number",
      "label": { "en": "Bin width", "fr": "Largeur" },
      "default": 5,
      "min": 0.1,
      "max": 1000,
      "visibleWhen": [
        { "field": "plotType", "value": "histogram" },
        { "field": "binMode", "value": "width" }
      ],
      "row": "binRow",
      "section": { "en": "Chart", "fr": "Graphique" }
    },
    "xLabel": {
      "type": "string",
      "label": { "en": "X axis label", "fr": "Légende axe X" },
      "default": "",
      "row": "axisLabels",
      "section": { "en": "Chart", "fr": "Graphique" }
    },
    "yLabel": {
      "type": "string",
      "label": { "en": "Y axis label", "fr": "Légende axe Y" },
      "default": "",
      "row": "axisLabels",
      "section": { "en": "Chart", "fr": "Graphique" }
    },
    "decimals": {
      "type": "number",
      "label": { "en": "Decimals", "fr": "Décimales" },
      "default": 1,
      "min": 0,
      "max": 10,
      "row": "axisOptions",
      "section": { "en": "Chart", "fr": "Graphique" }
    },
    "xAxisStartZero": {
      "type": "boolean",
      "label": { "en": "X axis starts at 0", "fr": "Axe X commence à 0" },
      "default": false,
      "row": "axisOptions",
      "section": { "en": "Chart", "fr": "Graphique" }
    },
    "showGrid": {
      "type": "boolean",
      "label": { "en": "Show grid", "fr": "Grille" },
      "default": true,
      "row": "axisOptions",
      "section": { "en": "Chart", "fr": "Graphique" }
    },
    "showLegend": {
      "type": "boolean",
      "label": { "en": "Show legend", "fr": "Légende" },
      "default": true,
      "row": "legendRow",
      "section": { "en": "Chart", "fr": "Graphique" }
    },
    "legendPosition": {
      "type": "select",
      "label": { "en": "Legend position", "fr": "Position légende" },
      "default": "bottom",
      "row": "legendRow",
      "section": { "en": "Chart", "fr": "Graphique" },
      "visibleWhen": { "field": "showLegend", "value": true },
      "options": [
        { "value": "bottom", "label": { "en": "Bottom", "fr": "En bas" } },
        { "value": "top-right", "label": { "en": "Top right", "fr": "Haut droite" } },
        { "value": "top-left", "label": { "en": "Top left", "fr": "Haut gauche" } },
        { "value": "top-center", "label": { "en": "Top center", "fr": "Haut centre" } }
      ]
    },

    "cardIcon": {
      "type": "icon-select",
      "label": { "en": "Icon", "fr": "Icône" },
      "default": "__none__",
      "row": "iconRow",
      "section": { "en": "Style", "fr": "Style", "defaultOpen": false }
    },
    "centerTitle": {
      "type": "boolean",
      "label": { "en": "Center title", "fr": "Centrer le titre" },
      "default": false,
      "row": "iconRow",
      "section": { "en": "Style", "fr": "Style", "defaultOpen": false }
    },
    "cardColor": {
      "type": "color-select",
      "label": { "en": "Main", "fr": "Principale" },
      "default": "none",
      "row": "colorsRow",
      "section": { "en": "Style", "fr": "Style", "defaultOpen": false },
      "description": {
        "en": "Primary chart color (when no grouping).",
        "fr": "Couleur principale du graphique (sans regroupement)."
      }
    },
    "bgColor": {
      "type": "color-select",
      "label": { "en": "Background", "fr": "Fond" },
      "default": "none",
      "row": "colorsRow",
      "section": { "en": "Style", "fr": "Style", "defaultOpen": false },
      "options": [
        { "value": "none", "label": { "en": "None", "fr": "Aucun" } }
      ]
    },
    "titleColor": {
      "type": "color-select",
      "label": { "en": "Title", "fr": "Titre" },
      "default": "auto",
      "row": "colorsRow",
      "section": { "en": "Style", "fr": "Style", "defaultOpen": false },
      "options": [
        { "value": "auto", "label": { "en": "Auto", "fr": "Auto" } }
      ]
    },
    "colorPalette": {
      "type": "select",
      "label": { "en": "Color palette", "fr": "Palette" },
      "default": "default",
      "section": { "en": "Style", "fr": "Style", "defaultOpen": false },
      "options": [
        { "value": "default", "label": { "en": "Default", "fr": "Par défaut" } },
        { "value": "tableau10", "label": { "en": "Tableau 10", "fr": "Tableau 10" } },
        { "value": "pastel", "label": { "en": "Pastel", "fr": "Pastel" } },
        { "value": "vivid", "label": { "en": "Vivid", "fr": "Vives" } },
        { "value": "earth", "label": { "en": "Earth tones", "fr": "Tons terre" } },
        { "value": "ocean", "label": { "en": "Ocean", "fr": "Océan" } },
        { "value": "warm", "label": { "en": "Warm", "fr": "Chaud" } },
        { "value": "cool", "label": { "en": "Cool", "fr": "Froid" } },
        { "value": "monochrome", "label": { "en": "Monochrome", "fr": "Monochrome" } },
        { "value": "custom", "label": { "en": "Custom…", "fr": "Personnalisée…" } }
      ]
    },
    "customPalette": {
      "type": "palette-editor",
      "label": { "en": "Custom colors", "fr": "Couleurs personnalisées" },
      "default": "",
      "visibleWhen": { "field": "colorPalette", "value": "custom" },
      "section": { "en": "Style", "fr": "Style", "defaultOpen": false }
    },
    "opacity": {
      "type": "number",
      "label": { "en": "Opacity (%)", "fr": "Opacité (%)" },
      "default": 70,
      "min": 0,
      "max": 100,
      "row": "opacitySize",
      "section": { "en": "Style", "fr": "Style", "defaultOpen": false }
    },
    "pointSize": {
      "type": "number",
      "label": { "en": "Point / line size", "fr": "Taille points / lignes" },
      "default": 4,
      "min": 1,
      "max": 15,
      "row": "opacitySize",
      "section": { "en": "Style", "fr": "Style", "defaultOpen": false }
    }
  }
}
