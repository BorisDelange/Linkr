{
  "id": "linkr-analysis-correlation",
  "name": {
    "en": "Correlation Matrix",
    "fr": "Matrice de corrélation"
  },
  "description": {
    "en": "Pearson correlation matrix for numeric variables with color-coded heatmap.",
    "fr": "Matrice de corrélation de Pearson pour les variables numériques avec carte thermique colorée."
  },
  "version": "1.0.0",
  "category": "analysis",
  "tags": ["descriptive", "correlation", "heatmap"],
  "runtime": ["script"],
  "languages": ["python", "r"],
  "icon": "GitCompareArrows",
  "configSchema": {
    "selectedColumns": {
      "type": "column-select",
      "multi": true,
      "filter": "numeric",
      "label": { "en": "Numeric variables", "fr": "Variables numériques" },
      "defaultAll": true
    },
    "method": {
      "type": "select",
      "label": { "en": "Method", "fr": "Méthode" },
      "default": "pearson",
      "options": [
        { "value": "pearson", "label": { "en": "Pearson", "fr": "Pearson" } },
        { "value": "spearman", "label": { "en": "Spearman", "fr": "Spearman" } },
        { "value": "kendall", "label": { "en": "Kendall", "fr": "Kendall" } }
      ]
    }
  },
  "dependencies": {
    "python": [],
    "r": []
  },
  "templates": {
    "python": "correlation.py.template",
    "r": "correlation.R.template"
  }
}
