{
  "id": "linkr-analysis-table1",
  "name": {
    "en": "Table 1",
    "fr": "Tableau 1"
  },
  "description": {
    "en": "Descriptive statistics table with counts, percentages, means, medians, and IQR for each variable. Supports optional group-by.",
    "fr": "Tableau de statistiques descriptives avec effectifs, pourcentages, moyennes, médianes et IQR pour chaque variable. Supporte un regroupement optionnel."
  },
  "version": "1.0.0",
  "category": "analysis",
  "tags": ["descriptive", "table"],
  "runtime": ["component"],
  "languages": [],
  "icon": "TableIcon",
  "configSchema": {
    "selectedColumns": {
      "type": "column-select",
      "multi": true,
      "label": { "en": "Variables", "fr": "Variables" },
      "defaultAll": true
    },
    "groupByColumn": {
      "type": "column-select",
      "multi": false,
      "optional": true,
      "filter": "categorical",
      "label": { "en": "Group by", "fr": "Grouper par" }
    },
    "metrics": {
      "type": "select",
      "multi": true,
      "label": { "en": "Metrics", "fr": "Métriques" },
      "defaultAll": true,
      "options": [
        { "value": "n", "label": { "en": "n", "fr": "n" } },
        { "value": "missing", "label": { "en": "Missing", "fr": "Manquants" } },
        { "value": "mean_sd", "label": { "en": "Mean ± SD", "fr": "Moyenne ± ET" } },
        { "value": "median_iqr", "label": { "en": "Median [IQR]", "fr": "Médiane [IQR]" } },
        { "value": "min_max", "label": { "en": "Min / Max", "fr": "Min / Max" } },
        { "value": "range", "label": { "en": "Range", "fr": "Étendue" } },
        { "value": "categories", "label": { "en": "Categories", "fr": "Catégories" } }
      ]
    }
  }
}
