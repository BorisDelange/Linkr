{
  "name": "linkr",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --port 8000",
    "dev:all": "concurrently \"npm run dev:web\" \"npm run dev:api\""
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
